{
  "name": "cas-express-majahual",
  "version": "1.0.!PATCH!",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/patch-expo-router.js",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron:dev": "electron electron/main.js",
    "electron:build": "expo export --platform web --output-dir dist && electron-builder",
    "electron:pack": "electron-builder --dir",
    "cap:build": "expo export --platform web --output-dir dist",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:apk": "expo export --platform web --output-dir dist && npx cap sync android && cd android && gradlew assembleRelease"
  },
  "dependencies": {
    "electron-serve": "^1.3.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@babel/core": "^7.24.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@expo/vector-icons": "^13.0.0",
    "@react-native-async-storage/async-storage": "1.18.2",
    "@types/react": "~18.2.79",
    "@types/react-native": "^0.72.8",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "expo": "~49.0.23",
    "expo-asset": "~9.0.2",
    "expo-constants": "~14.4.2",
    "expo-font": "~11.4.0",
    "expo-image-picker": "~14.3.2",
    "expo-linking": "~5.0.2",
    "expo-print": "~12.4.2",
    "expo-router": "~2.0.0",
    "expo-sharing": "~11.5.0",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "~1.6.0",
    "firebase": "^10.12.0",
    "firebase-admin": "^13.10.0",
    "jspdf": "^4.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.10",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-paper": "^5.12.3",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.0",
    "react-native-web": "~0.19.10",
    "sharp": "^0.35.2",
    "typescript": "^5.3.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.casexpress.majahual",
    "productName": "CAS Express Majahual",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "assets/icon.ico",
      "assets/icon.png"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CAS Majahual"
    },
    "publish": {
      "provider": "github",
      "owner": "bralex23",
      "repo": "cas-express-majahual",
      "releaseType": "release"
    }
  }
}
